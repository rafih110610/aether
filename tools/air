#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="${HOME}/.config/aether"
CONFIG_FILE="${CONFIG_DIR}/air.env"

AETHERPKG_INDEX=""
AIR_REGISTRY_REPO=""
AIR_REGISTRY_REF="main"
AIR_REGISTRY_INDEX_PATH="packages/index.txt"

usage() {
  cat <<'EOF'
Usage:
  air init
  air install [--local|--global] <name> [source]
  air uninstall [--local|--global] <name>
  air update [--local|--global] [name]
  air search <query>
  air list [--local|--global]
  air index
  air publish <name> <package-file> [description] [--no-push]

Registry:
  air registry show
  air registry set <url-or-path>
  air registry github <owner/repo> [ref] [index-path]
  air registry reset

Examples:
  air registry github my-org/aether-registry main packages/index.txt
  air search color
  air install colors
  air install --global colors
  air publish colors ./packages/colors.ath "Basic color constants"
EOF
}

check_remote_registry_url() {
  local url="$1"
  if ! command -v curl >/dev/null 2>&1; then
    return 0
  fi

  if ! curl -fsSL --connect-timeout 5 --max-time 12 "$url" -o /dev/null; then
    echo "Warning: registry index is not reachable yet: $url" >&2
    echo "Make sure the file exists in the repo (for example packages/index.txt)." >&2
  fi
}

remote_url_exists() {
  local url="$1"
  if ! command -v curl >/dev/null 2>&1; then
    return 1
  fi
  curl -fsSL --connect-timeout 5 --max-time 12 "$url" -o /dev/null 2>/dev/null
}

ensure_config_dir() {
  mkdir -p "$CONFIG_DIR"
}

load_config() {
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
  fi
}

write_config() {
  ensure_config_dir
  {
    printf "AETHERPKG_INDEX=%q\n" "$AETHERPKG_INDEX"
    printf "AIR_REGISTRY_REPO=%q\n" "$AIR_REGISTRY_REPO"
    printf "AIR_REGISTRY_REF=%q\n" "$AIR_REGISTRY_REF"
    printf "AIR_REGISTRY_INDEX_PATH=%q\n" "$AIR_REGISTRY_INDEX_PATH"
  } > "$CONFIG_FILE"
}

normalize_github_slug() {
  local input="$1"
  local slug="$input"

  if [[ "$slug" =~ ^https?://github.com/ ]]; then
    slug="${slug#https://github.com/}"
    slug="${slug#http://github.com/}"
  fi
  slug="${slug%.git}"
  slug="${slug%/}"

  if [[ ! "$slug" =~ ^[^/]+/[^/]+$ ]]; then
    echo "Invalid GitHub repo. Use owner/repo or https://github.com/owner/repo(.git)" >&2
    exit 1
  fi

  printf "%s" "$slug"
}

get_registry() {
  load_config
  if [[ -n "${AETHERPKG_INDEX:-}" ]]; then
    printf "%s" "$AETHERPKG_INDEX"
    return
  fi
  printf ""
}

set_registry() {
  local value="$1"
  load_config
  AETHERPKG_INDEX="$value"
  write_config
  echo "Registry set to: $value"
}

reset_registry() {
  AETHERPKG_INDEX=""
  AIR_REGISTRY_REPO=""
  AIR_REGISTRY_REF="main"
  AIR_REGISTRY_INDEX_PATH="packages/index.txt"
  write_config
  echo "Registry reset. aetherpkg defaults will be used."
}

normalize_path_if_local() {
  local value="$1"
  if [[ "$value" =~ ^https?:// ]]; then
    printf "%s" "$value"
    return
  fi
  if [[ "$value" = /* ]]; then
    printf "%s" "$value"
    return
  fi
  printf "%s" "$(pwd)/$value"
}

pkg_exec() {
  local pkg_cmd
  pkg_cmd="${SCRIPT_DIR}/aetherpkg"
  if [[ ! -x "$pkg_cmd" ]]; then
    pkg_cmd="$(command -v aetherpkg || true)"
  fi

  if [[ -z "$pkg_cmd" ]]; then
    echo "aetherpkg not found. Expected at ${SCRIPT_DIR}/aetherpkg or in PATH." >&2
    exit 1
  fi

  local reg
  reg="$(get_registry)"
  if [[ -n "$reg" ]]; then
    AETHERPKG_INDEX="$reg" "$pkg_cmd" "$@"
  else
    "$pkg_cmd" "$@"
  fi
}

cmd_registry() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 2
  fi

  local sub="$1"
  shift

  case "$sub" in
    show)
      load_config
      local reg
      reg="$(get_registry)"
      if [[ -n "$reg" ]]; then
        echo "Registry: $reg"
      else
        echo "Registry: default (aetherpkg internal default)"
      fi
      if [[ -n "$AIR_REGISTRY_REPO" ]]; then
        echo "Publish repo: $AIR_REGISTRY_REPO"
        echo "Publish ref: ${AIR_REGISTRY_REF:-main}"
        echo "Publish index path: ${AIR_REGISTRY_INDEX_PATH:-packages/index.txt}"
      fi
      ;;
    set)
      if [[ $# -ne 1 ]]; then
        usage
        exit 2
      fi
      set_registry "$(normalize_path_if_local "$1")"
      ;;
    github)
      if [[ $# -lt 1 || $# -gt 3 ]]; then
        usage
        exit 2
      fi
      local repo
      repo="$(normalize_github_slug "$1")"
      local ref="${2:-main}"
      local index_path="${3:-}"
      if [[ -z "$index_path" ]]; then
        local candidate_packages="https://raw.githubusercontent.com/${repo}/${ref}/packages/index.txt"
        local candidate_root="https://raw.githubusercontent.com/${repo}/${ref}/index.txt"
        if remote_url_exists "$candidate_packages"; then
          index_path="packages/index.txt"
        elif remote_url_exists "$candidate_root"; then
          index_path="index.txt"
        else
          index_path="packages/index.txt"
        fi
      fi
      local url="https://raw.githubusercontent.com/${repo}/${ref}/${index_path}"
      load_config
      AIR_REGISTRY_REPO="$repo"
      AIR_REGISTRY_REF="$ref"
      AIR_REGISTRY_INDEX_PATH="$index_path"
      AETHERPKG_INDEX="$url"
      write_config
      echo "Registry set to: $url"
      echo "GitHub registry URL: $url"
      check_remote_registry_url "$url"
      ;;
    reset)
      reset_registry
      ;;
    *)
      usage
      exit 2
      ;;
  esac
}

update_index_entry() {
  local index_file="$1"
  local name="$2"
  local source="$3"
  local description="$4"

  local tmp
  tmp="$(mktemp)"

  awk -F'|' -v pkg="$name" '
    /^[[:space:]]*#/ { print; next }
    NF == 0 { print; next }
    {
      raw=$1
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", raw)
      if (raw != pkg) {
        print
      }
    }
  ' "$index_file" > "$tmp"

  printf "%s|%s|%s\n" "$name" "$source" "$description" >> "$tmp"
  mv "$tmp" "$index_file"
}

resolve_repo_clone_url() {
  local repo_input="$1"
  if [[ -d "$repo_input/.git" ]] || [[ -d "$repo_input" ]]; then
    printf "%s" "$repo_input"
    return
  fi
  if [[ "$repo_input" = /* ]] || [[ "$repo_input" == ./* ]] || [[ "$repo_input" == ../* ]]; then
    printf "%s" "$repo_input"
    return
  fi
  if [[ "$repo_input" =~ ^https?:// ]] || [[ "$repo_input" =~ ^git@ ]]; then
    printf "%s" "$repo_input"
    return
  fi
  printf "%s" "https://github.com/${repo_input}.git"
}

cmd_publish() {
  if [[ $# -lt 2 ]]; then
    usage
    exit 2
  fi

  local name="$1"
  local package_file="$2"
  shift 2

  if [[ ! "$name" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]]; then
    echo "Invalid package name: $name" >&2
    exit 1
  fi

  if [[ ! -f "$package_file" ]]; then
    echo "Package file not found: $package_file" >&2
    exit 1
  fi

  local description="Published via air"
  if [[ $# -gt 0 && "$1" != --* ]]; then
    description="$1"
    shift
  fi

  load_config
  local repo="${AIR_REGISTRY_REPO:-}"
  local ref="${AIR_REGISTRY_REF:-main}"
  local index_path="${AIR_REGISTRY_INDEX_PATH:-packages/index.txt}"
  local no_push="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --registry-repo)
        [[ $# -ge 2 ]] || { echo "Missing value for --registry-repo" >&2; exit 2; }
        repo="$2"
        shift 2
        ;;
      --ref)
        [[ $# -ge 2 ]] || { echo "Missing value for --ref" >&2; exit 2; }
        ref="$2"
        shift 2
        ;;
      --index-path)
        [[ $# -ge 2 ]] || { echo "Missing value for --index-path" >&2; exit 2; }
        index_path="$2"
        shift 2
        ;;
      --no-push)
        no_push="true"
        shift
        ;;
      *)
        echo "Unknown option: $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ -z "$repo" ]]; then
    echo "No publish registry repo configured." >&2
    echo "Run: air registry github <owner/repo> [ref] [index-path]" >&2
    echo "Or pass: --registry-repo <owner/repo|url|local-path>" >&2
    exit 1
  fi

  if ! command -v git >/dev/null 2>&1; then
    echo "git is required for air publish" >&2
    exit 1
  fi

  local clone_url
  clone_url="$(resolve_repo_clone_url "$repo")"

  local tmp_dir
  tmp_dir="$(mktemp -d)"
  local registry_dir="$tmp_dir/registry"

  if ! git clone --depth 1 --branch "$ref" "$clone_url" "$registry_dir" >/dev/null 2>&1; then
    echo "Failed to clone registry repo: $clone_url (branch: $ref)" >&2
    rm -rf "$tmp_dir"
    exit 1
  fi

  local index_file="$registry_dir/$index_path"
  local index_dir
  index_dir="$(dirname "$index_file")"
  local index_rel_dir
  index_rel_dir="$(dirname "$index_path")"
  mkdir -p "$index_dir"
  if [[ ! -f "$index_file" ]]; then
    printf "# name|source|description\n" > "$index_file"
  fi

  local dest_pkg="$index_dir/${name}.ath"
  cp "$package_file" "$dest_pkg"

  update_index_entry "$index_file" "$name" "./${name}.ath" "$description"

  (
    cd "$registry_dir"
    git add "$index_path" "$index_rel_dir/${name}.ath"
    if git diff --cached --quiet; then
      echo "No publish changes detected for package '$name'."
      exit 0
    fi
    git commit -m "air publish: ${name}" >/dev/null
  )

  if [[ "$no_push" == "true" ]]; then
    echo "Published locally (no push) in: $registry_dir"
    echo "Run these commands to push:"
    echo "  cd $registry_dir"
    echo "  git push origin $ref"
    return
  fi

  if ! (cd "$registry_dir" && git push origin "$ref"); then
    echo "Push failed. You may need GitHub auth (SSH key or token)." >&2
    echo "Your prepared publish commit is at: $registry_dir" >&2
    echo "Manual push: cd $registry_dir && git push origin $ref" >&2
    return 1
  fi

  echo "Published '$name' to registry '$repo' on branch '$ref'."
  rm -rf "$tmp_dir"
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 2
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    init|install|add|uninstall|remove|rm|update|upgrade|search|find|list|index)
      pkg_exec "$cmd" "$@"
      ;;
    publish)
      cmd_publish "$@"
      ;;
    registry)
      cmd_registry "$@"
      ;;
    help|--help|-h)
      usage
      ;;
    *)
      usage
      exit 2
      ;;
  esac
}

main "$@"
